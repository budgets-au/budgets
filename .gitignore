# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-e2e/
/out/

# playwright e2e
/test-results/
/playwright-report/
/blob-report/
/tests/e2e/.data/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# CSV / OFX / QIF samples that drive the import regression tests —
# kept locally on dev machines but never committed since they're
# real-world bank exports (even anonymised, the financial pattern
# is operator-specific). Tests skip the suite when the fixture is
# missing.
/tests/fixtures/

# SQLite live data — the file is too big to track and contains PII; the
# host should keep its own copy mounted at SQLITE_PATH (./data in dev,
# /data inside the container).
/data/

.claude/
