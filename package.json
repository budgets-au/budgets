{
  "name": "budgets",
  "version": "0.9.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --reporter=default --reporter=json --outputFile=tests/e2e/.data/vitest-report-raw.json && node scripts/vitest-summary.mjs",
    "test:watch": "vitest",
    "test:report": "pnpm test",
    "test:e2e": "playwright test",
    "coverage": "node scripts/coverage.mjs",
    "coverage:unit": "vitest run --coverage",
    "coverage:e2e": "COLLECT_COVERAGE=1 playwright test",
    "coverage:e2e-report": "NODE_OPTIONS='--max-old-space-size=8192' c8 report --reporter=json --temp-directory=.coverage/e2e/raw --reports-dir=.coverage/e2e --include='src/**' --exclude='**/*.test.*' --exclude='**/*.spec.*' --exclude='**/*.d.ts'",
    "coverage:report": "node scripts/coverage-merge.mjs",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "docker:release": "node scripts/docker-release.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@signalapp/better-sqlite3": "^9.0.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react-grid-layout": "^1.3.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "npm:@signalapp/better-sqlite3@^9.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-dropzone": "^15.0.0",
    "react-grid-layout": "^2.2.3",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.43",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "c8": "^11.0.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.6",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@signalapp/better-sqlite3",
      "bcryptjs",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "tar": ">=7.5.11",
      "postcss": ">=8.5.10",
      "esbuild": ">=0.25.0",
      "fast-uri": ">=3.1.2",
      "ip-address": ">=10.1.1",
      "hono": ">=4.12.18",
      "picomatch": ">=4.0.0",
      "brace-expansion": ">=5.0.6",
      "qs": ">=6.15.2"
    }
  }
}
