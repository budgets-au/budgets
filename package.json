{
  "name": "budgets",
  "version": "0.9.0",
  "description": "Self-hosted household budget tracker.",
  "author": "budgets-au",
  "main": "electron/main.cjs",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "docker:release": "node scripts/docker-release.mjs",
    "electron:rebuild": "electron-builder install-app-deps",
    "electron:prepare": "next build && node scripts/electron-prepare.mjs",
    "electron:dev": "pnpm electron:rebuild && pnpm electron:prepare && electron electron/main.cjs",
    "electron:build:win": "pnpm electron:rebuild && pnpm electron:prepare && electron-builder --win --x64 --config electron-builder.yml --publish=never"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@signalapp/better-sqlite3": "^9.0.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react-grid-layout": "^1.3.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "npm:@signalapp/better-sqlite3@^9.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-grid-layout": "^2.2.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^16.4.7",
    "electron": "^33.4.6",
    "electron-builder": "^25.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@signalapp/better-sqlite3",
      "bcryptjs",
      "esbuild",
      "sharp"
    ],
    "overrides": {}
  }
}
